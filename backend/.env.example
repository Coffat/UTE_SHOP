# App
NODE_ENV=development
PORT=3000
CLIENT_ORIGIN=http://localhost:5174
APP_PUBLIC_URL=http://localhost:3000
# FRONTEND_URL: port phải khớp Vite dev server (5173 mặc định, 5174 nếu 5173 bận)
FRONTEND_URL=http://localhost:5174

# Database / Cache
MONGO_URI=mongodb://localhost:27017/uteshop
REDIS_URL=redis://127.0.0.1:6379

# Auth
ACCESS_TOKEN_SECRET=your_access_token_secret
REFRESH_TOKEN_SECRET=your_refresh_token_secret

# Mail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_password

# Payment - MoMo Sandbox
# Public demo credentials (https://github.com/momo-wallet/payment) — all three must match:
# MOMO_PARTNER_CODE=MOMOBKUN20180529
# MOMO_ACCESS_KEY=klm05TvNBzhg7h7j
# MOMO_SECRET_KEY=at67qH6mk8w5Y1nAyMoYKMWACiEi2bsa
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_REDIRECT_URL=
MOMO_IPN_URL=

# Payment - VNPAY Sandbox
# Lấy TMN Code + Hash Secret tại https://sandbox.vnpayment.vn/merchantv2/ (phải khớp cặp).
# Đăng ký Return URL + IPN URL trong merchant portal — URL ngrok phải trùng .env sau khi sync.
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=
VNPAY_IPN_URL=

# Payment behavior
PAYMENT_PENDING_TTL_MINUTES=30

# AI - Ollama local + OpenRouter
AI_ENABLED=true
AI_DEFAULT_PROVIDER=ollama
# Ollama: gemma4:e4b | OpenRouter free: openrouter/free hoặc google/gemma-4-26b-a4b-it:free
AI_DEFAULT_MODEL_ID=gemma4:e4b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://uteshop.vn
OPENROUTER_APP_NAME=UTESHOP
AI_HEALTH_PING_ENABLED=true
AI_TOOL_CALLING_ENABLED=true
MAX_TOOL_CALLS_PER_AI_RESPONSE=1
AI_TOOL_DECISION_MAX_PREDICT_TOKENS=180
AI_TOOL_DECISION_TEMPERATURE=0.1
AI_ENABLED_TOOL_NAMES=handoffToStaff,searchProducts,getProductDetail,checkOrderStatus
AI_REQUEST_TIMEOUT_MS=45000
AI_STREAM_LOCK_MAX_MS=120000
AI_MAX_HISTORY_MESSAGES=12
AI_MAX_PREDICT_TOKENS=700
AI_TEMPERATURE=0.4

# GHN API Configuration
GHN_API_URL=https://dev-online-gateway.ghn.vn/shiip/public-api
GHN_API_TOKEN=your_ghn_api_token
GHN_SHOP_ID=your_ghn_shop_id
GHN_FROM_DISTRICT_ID=your_ghn_from_district_id

# OAuth Social Login Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
